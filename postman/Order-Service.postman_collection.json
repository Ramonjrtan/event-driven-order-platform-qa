{
  "info": {
    "name": "Order Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "orders"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"CUST-1001\",\n  \"itemId\": \"SKU-001\",\n  \"quantity\": 2,\n  \"amount\": 120.0\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 202', function () {",
              "  pm.expect([201,202]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}